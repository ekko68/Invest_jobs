    <!--    메시지 읽음 처리-->
    <update id="updateMessageRead" parameterType="String">
        UPDATE
            <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M
        SET
            CNFA_YN         = 'Y'
            , AMNN_USER_ID  = #{amnnUserId}
            , AMNN_TS       = CURRENT_TIMESTAMP
        WHERE
            MSG_ID = #{msgId}
    </update>

    <!--    전체 메시지 읽음 처리-->
    <update id="updateMessageReadAllSeparateByListType" parameterType="RequestMessageReadAllVO">
        UPDATE
            <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M
        SET
            CNFA_YN         = 'Y'
            , AMNN_USER_ID  = #{amnnUserId}
            , AMNN_TS       = CURRENT_TIMESTAMP
        WHERE
            MSG_ID IN (
                SELECT main.MSG_ID
                FROM <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M main
                LEFT JOIN <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M prns ON main.PRNS_MSG_ID = prns.MSG_ID
                WHERE main.RCV_INTT_ID = #{rcvInttId} AND main.CNFA_YN != 'Y'
                <choose>
                    <when test="listType != null and listType.equals(RECEIVE)">
                        AND (main.PRNS_MSG_ID IS NULL OR prns.RCV_INTT_ID = #{rcvInttId})
                    </when>
                    <when test="listType != null and listType.equals(SEND)">
                        AND prns.DSMS_INTT_ID = #{rcvInttId}
                    </when>
                </choose>
            )
    </update>

