    <!--    수신 / 발신 메시지 목록 조회 : 메시지 목록 분리 작업3 : 수신 발신만으로 구분-->
    <select id="selectMessageList" parameterType="RequestMessageVO" resultType="MessageSummaryVO">
        <include refid="pagingHeader"/>
            SELECT
                main.MSG_ID
                , CASE WHEN main.PRNS_MSG_ID IS NULL THEN 'N' ELSE 'Y' END AS REPLY_YN
                , main.PRNS_MSG_ID

                , main.DSMS_INTT_ID
                , trnt_eim.ETNM AS TRNT_BPLC_NM
                , main.RCV_INTT_ID
                , rcvr_eim.ETNM AS RCVR_BPLC_NM

                , main.RGSN_USER_ID
                , main.RGSN_USER_NM
                , main.RGSN_TS
                , CASE
                    WHEN main.DSMS_INTT_ID = #{utlinsttId} THEN 'N'
                    WHEN main.RGSN_TS IS NULL THEN 'N'
                    WHEN TO_CHAR(main.RGSN_TS, 'YYYYMMDDHH24MISS') > TO_CHAR(SYSDATE-24/24, 'YYYYMMDDHH24MISS') THEN 'Y'
                    ELSE 'N' END AS RCV_IN_ONE_DAY_YN

                , main.MSG_PTRN_CD
                , ccd.COM_CD_NM AS MSG_PTRN_NM
                , main.MSG_TTL

                , CASE WHEN main.RCV_INTT_ID = #{utlinsttId} THEN main.CNFA_YN ELSE NULL END AS CNFA_YN
                , CASE WHEN file_cnt.FILE_COUNT != 0 THEN 'Y' ELSE 'N' END AS FILE_YN

            FROM
                <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M main
            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M trnt_eim ON trnt_eim.UTLINSTT_ID = main.DSMS_INTT_ID
            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M rcvr_eim ON rcvr_eim.UTLINSTT_ID = main.RCV_INTT_ID
            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_COM_CD_D ccd ON ccd.COM_CD_ID = main.MSG_PTRN_CD
            LEFT JOIN (
                SELECT MSG_ID, NVL(COUNT(0), 0) AS FILE_COUNT
                FROM <include refid="INVEST"/>TB_BOX_IVT_MSG_ATCH_R
                GROUP BY MSG_ID
            ) file_cnt ON file_cnt.MSG_ID = main.MSG_ID

            WHERE 1=1
                <choose>
                    <when test="listType != null and listType.equals(RECEIVE_LIST)">
                        AND main.RCV_INTT_ID = #{utlinsttId}
                    </when>
                    <when test="listType != null and listType.equals(SEND_LIST)">
                        AND main.DSMS_INTT_ID = #{utlinsttId}
                    </when>
                    <otherwise>
                        AND (main.RCV_INTT_ID = #{utlinsttId} OR main.DSMS_INTT_ID = #{utlinsttId})
                    </otherwise>
                </choose>
                <if test="searchStr != null and !searchStr.equals('')">
                    AND (
                        UPPER(main.MSG_TTL) LIKE '%'||UPPER(#{searchStr})||'%'

                        <choose>
                            <when test="listType != null and listType.equals(RECEIVE_LIST)">
                                OR UPPER(trnt_eim.ETNM) LIKE '%'||UPPER(#{searchStr})||'%'
                            </when>
                            <when test="listType != null and listType.equals(SEND_LIST)">
                                OR UPPER(rcvr_eim.ETNM) LIKE '%'||UPPER(#{searchStr})||'%'
                            </when>
                        </choose>
                    )
                </if>
            ORDER BY
                main.RGSN_TS DESC
        <include refid="pagingFooter"/>
    </select>


    <!--    투자심사 메시지 리스트 조회-->
    <select id="selectAuditMessageList" parameterType="RequestAuditMessageVO" resultType="MessageSummaryVO">
        <include refid="pagingHeader"/>

            SELECT
                m2.PARENT_RG
                , m2.MSG_ID AS PARENT_ID
                , CASE WHEN PRNS_MSG_ID IS NULL THEN 'N' ELSE 'Y' END AS REPLY_YN

                , m1.MSG_ID
                , mapp.INVM_EXNT_RQST_ID

                , m1.DSMS_INTT_ID
                , m1.RCV_INTT_ID
                , m1.RGSN_USER_ID
                , m1.RGSN_USER_NM
                , trnt_eim.ETNM AS TRNT_BPLC_NM
                , rcvr_eim.ETNM AS RCVR_BPLC_NM

                , m1.MSG_TTL
                , m1.RGSN_TS

                , m1.MSG_PTRN_CD
                , ccd_msg.COM_CD_NM AS MSG_PTRN_NM

                , m1.PRNS_MSG_ID
                , CASE WHEN file_cnt.FILE_COUNT != 0 THEN 'Y' ELSE 'N' END AS FILE_YN
            FROM
                <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M m1
            LEFT JOIN
            (
                SELECT
                MSG_ID
                , RGSN_TS AS PARENT_RG
                FROM
                <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M m1
                WHERE
                PRNS_MSG_ID IS NULL
            ) m2
            ON m1.PRNS_MSG_ID = m2.MSG_ID OR m1.MSG_ID = m2.MSG_ID

            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M trnt_eim ON trnt_eim.UTLINSTT_ID = m1.DSMS_INTT_ID
            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M rcvr_eim ON rcvr_eim.UTLINSTT_ID = m1.RCV_INTT_ID

            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_EXNT_MSG_R mapp ON mapp.MSG_ID = m1.MSG_ID
            LEFT JOIN
                <include refid="INVEST"/>TB_BOX_IVT_COM_CD_D ccd_msg ON ccd_msg.COM_CD_ID = m1.MSG_PTRN_CD

            LEFT JOIN (
                SELECT MSG_ID, NVL(COUNT(0), 0) AS FILE_COUNT
                FROM <include refid="INVEST"/>TB_BOX_IVT_MSG_ATCH_R
                GROUP BY MSG_ID
            ) file_cnt ON file_cnt.MSG_ID = m1.MSG_ID

            <!-- 투자사 전환 대응-->
<!--            LEFT JOIN-->
<!--                <include refid="INVEST"/>TB_BOX_IVT_VNCM_CPTL_L dsms_vc_chk ON m1.DSMS_INTT_ID = dsms_vc_chk.UTLINSTT_ID-->
<!--            LEFT JOIN-->
<!--                <include refid="INVEST"/>TB_BOX_IVT_VNCM_CPTL_L rcv_vc_chk ON m1.RCV_INTT_ID = rcv_vc_chk.UTLINSTT_ID-->

            WHERE mapp.INVM_EXNT_RQST_ID = #{invmExntRqstId}
            <!--    메시지 타입이 투자심사 문의인 경우만 -->
            AND m1.MSG_PTRN_CD = #{MESSAGE_AUDIT_CODE}

            <!-- 투자사 전환 대응-->
<!--            <![CDATA[-->
<!--                AND (CASE-->
<!--                WHEN dsms_vc_chk.RGSN_TS IS NULL THEN 'Y'-->
<!--                WHEN TO_CHAR(dsms_vc_chk.RGSN_TS, 'YYYYMMDDHH24MISS') <= m1.RGSN_TS THEN 'Y'-->
<!--                ELSE 'N' END) = 'Y'-->
<!--                AND (CASE-->
<!--                WHEN rcv_vc_chk.RGSN_TS IS NULL THEN 'Y'-->
<!--                WHEN TO_CHAR(rcv_vc_chk.RGSN_TS, 'YYYYMMDDHH24MISS') <= m1.RGSN_TS THEN 'Y'-->
<!--                ELSE 'N' END) = 'Y'-->
<!--            ]]>-->

            ORDER BY
                m2.PARENT_RG DESC, PARENT_ID DESC, m1.RGSN_TS ASC

        <include refid="pagingFooter"/>
    </select>

    <!--    메시지 상세 조회-->
    <select id="selectMessage" parameterType="String" resultType="MessageVO">
        SELECT
            tbim.MSG_ID
            , tbim.DSMS_INTT_ID
            , tbim.RCV_INTT_ID
            , tbim.RGSN_USER_ID
            , tbim.PRNS_MSG_ID

            , tbim.RGSN_USER_NM

            , mapp.INVM_EXNT_RQST_ID

            , trnt_eim.ETNM AS TRNT_BPLC_NM
            , rcvr_eim.ETNM AS RCVR_BPLC_NM

            , tbim.MSG_PTRN_CD
            , ccd.COM_CD_NM AS MSG_PTRN_NM

            , tbim.CNFA_YN
            , tbim.MSG_TTL
            , tbim.MSG_CON
            , tbim.RGSN_TS

        FROM
            <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M tbim
        LEFT JOIN
            <include refid="INVEST"/>TB_BOX_IVT_EXNT_MSG_R mapp ON mapp.MSG_ID = tbim.MSG_ID
        LEFT JOIN
            <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M trnt_eim ON trnt_eim.UTLINSTT_ID = tbim.DSMS_INTT_ID
        LEFT JOIN
            <include refid="INVEST"/>TB_BOX_IVT_ENPR_INFO_M rcvr_eim ON rcvr_eim.UTLINSTT_ID = tbim.RCV_INTT_ID
        LEFT JOIN
            <include refid="INVEST"/>TB_BOX_IVT_COM_CD_D ccd ON ccd.COM_CD_ID = tbim.MSG_PTRN_CD

        WHERE
            tbim.MSG_ID = #{msgId}
    </select>

    <!--    메시지 첨부파일 리스트 조회-->
    <select id="selectMessageFileList" parameterType="String" resultType="MessageFileVO">
        SELECT
        tbimfm.MSG_ID
        , tbimfm.ATCH_ID
        , tbivf.FILE_ID
        , tbivf.FILE_NM

        , tbimfm.RGSN_USER_ID
        , tbimfm.RGSN_TS
        FROM
            <include refid="INVEST"/>TB_BOX_IVT_MSG_ATCH_R tbimfm
        LEFT JOIN
            <include refid="INVEST"/>TB_BOX_IVT_FILE_ATCH_M tbivf ON tbimfm.ATCH_ID = tbivf.FILE_ID
        WHERE
            tbimfm.MSG_ID = #{msgId}
    </select>

    <!--    메시지 등록-->
    <insert id="insertMessage" parameterType="MessageVO">
        INSERT INTO <include refid="INVEST"/>TB_BOX_IVT_MSG_INFO_M
        (
            MSG_ID
            , DSMS_INTT_ID
            , RCV_INTT_ID
            , MSG_TTL
            , MSG_PTRN_CD
            , MSG_CON
            , PRNS_MSG_ID
            , CNFA_YN
            , RGSN_USER_ID
            , RGSN_TS
            , AMNN_USER_ID
            , AMNN_TS

            , RGSN_USER_NM
        )
        VALUES
        (
            #{msgId}
            , #{dsmsInttId}
            , #{rcvInttId}
            , #{msgTtl}
            , #{msgPtrnCd}
            , #{msgCon}
            , #{prnsMsgId}
            , 'N'
            , #{rgsnUserId}
            , CURRENT_TIMESTAMP
            , #{amnnUserId}
            , CURRENT_TIMESTAMP

            , #{rgsnUserNm}
        )
    </insert>

